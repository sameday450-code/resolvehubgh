# Environment Variables Template for Render Deployment

# Copy this file to your Render dashboard and fill in the values

# Environment
NODE_ENV=production
PORT=3000

# Database - REQUIRED
# Get this from your Render PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Secrets - GENERATE THESE
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL - Update after Vercel deployment
FRONTEND_URL=https://your-frontend.vercel.app

# Email Service (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@yourdomain.com
SMTP_SECURE=false
SMTP_TIMEOUT=10000

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Paystack Payment
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload Size (10MB)
MAX_FILE_SIZE=10485760

# Neon Auth (Optional - if using)
NEON_AUTH_URL=https://your-neon-auth-url
NEON_AUTH_JWKS_URL=https://your-neon-auth-jwks-url
